# Copy to .env and fill in your values.
# cp .env.example .env

# ── AWS S3 (model weights auto-downloaded on startup) ─────────────────────────
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET=brightmasker
S3_MODEL_PREFIX=models/pii_gliner

# ── Model ─────────────────────────────────────────────────────────────────────
FINE_TUNED_MODEL_PATH=models/pii_gliner
GLINER_THRESHOLD=0.35

# ── Security ──────────────────────────────────────────────────────────────────
ENCRYPTION_KEY=change-this-to-a-random-secret-key-in-production

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# ── RunPod remote model (leave empty to disable comparison panel) ─────────────
RUNPOD_BASE_URL=
