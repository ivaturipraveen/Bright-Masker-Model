# ─────────────────────────────────────────────────────────────────────────────
# Bright Masker Model — .gitignore
#
# Conventions:
#   • Trailing slash (foo/)  → ignore directory only
#   • No slash (foo)         → ignore at any depth
#   • Leading slash (/foo)   → anchor to repo root
# ─────────────────────────────────────────────────────────────────────────────


# ── Secrets & local environment ──────────────────────────────────────────────
# Never commit real credentials. Keep `.env.example` tracked as a template.
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test
.envrc
.direnv/

# Cloud / API credentials
*.pem
*.key
*.pfx
*.p12
*.crt
*.cer
credentials.json
service-account*.json
secrets.json
secrets.yaml
secrets.yml
.aws/
.gcp/
.ssh/


# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Distribution / packaging
build/
dist/
sdist/
wheels/
share/python-wheels/
*.egg
*.egg-info/
.eggs/
MANIFEST
pip-wheel-metadata/

# Type checkers / linters / formatters
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/
.pyre/
.ruff_cache/
.pylint.d/

# Testing / coverage
.tox/
.nox/
.pytest_cache/
.cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
nosetests.xml
*.cover
*.py,cover
.hypothesis/

# Profiling
*.prof
*.pyprof
*.lprof
profile.json


# ── Virtual environments ─────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.virtualenv/
.python-version


# ── Jupyter / notebooks ──────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints
profile_default/
ipython_config.py


# ─────────────────────────────────────────────────────────────────────────────
# Machine-learning artifacts
# ─────────────────────────────────────────────────────────────────────────────

# Model weights — large, downloaded from S3 / RunPod at runtime.
# (Keep `models/__init__.py` and `models/schemas.py` tracked; only ignore
# weight subdirectories and binary checkpoints.)
models/pii_gliner/
models/fine_tuned/
models/checkpoints/
models/cache/
checkpoints/

# Common ML weight & checkpoint formats — ignore at any depth.
*.bin
*.pt
*.pth
*.ckpt
*.safetensors
*.h5
*.hdf5
*.onnx
*.tflite
*.pb
*.gguf
*.msgpack

# HuggingFace / Transformers caches
.cache/
hf_cache/
transformers_cache/
.huggingface/

# Training framework outputs
runs/                    # TensorBoard
wandb/                   # Weights & Biases
mlruns/                  # MLflow
mlartifacts/
lightning_logs/
tb_logs/
ray_results/
outputs/                 # Hydra default
multirun/                # Hydra multirun
catboost_info/
lightgbm_info/

# Generated training data — regenerate via `python train/generate_data.py`.
train/data/
train/datasets/
data/raw/
data/processed/
data/interim/
data/external/


# ─────────────────────────────────────────────────────────────────────────────
# Project-specific generated artifacts
# ─────────────────────────────────────────────────────────────────────────────

# Validation / benchmark dumps — written per-run by Testing/verify_and_debug_pipeline.py
# Keep `Testing/validation_dataset.csv` (the input fixture) tracked.
Testing/validation_results_*.csv
Testing/validation_failures_*.csv
validation_results_*.csv
validation_failures_*.csv
benchmark_*.json
benchmark_*.csv
results_*.json
results_*.csv

# Large user-supplied validation corpora — too big to commit.
/Validation*.csv
/Validation*.json
/Validation*.parquet

# Smoke / ad-hoc test scripts and their fixtures.
# Smoke tests are local, throw-away verification scripts (Group A/B/C
# triage runs, regex pattern probes, etc.) — they live in the dev tree
# but should never be committed to the shared repo.
smoke_test*.py
smoke_test*.json
smoke_test*.csv
smoke_test*.txt
*_smoke.py
*_smoke.json
*_smoke_test.py
inspect_*_samples.py
scripts/smoke_*
Testing/smoke_*
tests/smoke_*

# Ad-hoc scratch files
test.txt
scratch.*
scratch/
playground.*
playground/
sandbox/
.notes/

# Output from masking / API testing
/tmp/
tmp/
temp/
*.tmp
*.bak
*.orig
*.rej


# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
*.log.*
logs/
log/
server.log
uvicorn.log
gunicorn.log
nohup.out
npm-debug.log*
yarn-debug.log*
yarn-error.log*


# ── Docker ───────────────────────────────────────────────────────────────────
docker-compose.override.yml
docker-compose.override.yaml
.docker/
.dockerignore.local


# ── IDE & editor ─────────────────────────────────────────────────────────────
# VS Code — keep workspace settings out of the repo.
.vscode/
*.code-workspace

# JetBrains family (PyCharm, IntelliJ, etc.)
.idea/
*.iml
*.iws
*.ipr

# Sublime
*.sublime-project
*.sublime-workspace

# Vim / Neovim
*.swp
*.swo
*.swn
*.un~
*~
[._]*.s[a-w][a-z]
[._]s[a-w][a-z]
Session.vim

# Emacs
\#*\#
.\#*
*.elc
auto-save-list
tramp

# Cursor — local IDE state.
.cursor/

# JetBrains Rider / Fleet
.fleet/


# ── OS-generated files ──────────────────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*


# ── Misc ─────────────────────────────────────────────────────────────────────
# Compressed archives left around after a release / experiment
*.zip
*.tar
*.tar.gz
*.tgz
*.tar.bz2
*.tbz2
*.7z
*.rar

# Local TLS / debugging dumps
*.har
*.pcap
core
core.*
